# Google Maps API Key
# Get your API key from: https://developers.google.com/maps/documentation/embed/get-api-key
# Enable the Maps Embed API in your Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Site owner email for booking inquiries
# This email will receive all booking inquiry submissions
VITE_SITE_EMAIL=your-email@example.com

# Optional: Resend API Key for email delivery
# Get from: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

